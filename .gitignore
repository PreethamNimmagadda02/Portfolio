# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/graphify-out

# repowise — ignore caches, sessions, jobs, secrets & vector DB
# Keep: config.yaml, wiki.db, state.json, knowledge-graph.json, mcp.json
.repowise/.env
.repowise/*.pkl
.repowise/lancedb/
.repowise/sessions/
.repowise/omissions/
.repowise/jobs/


package-lock.json